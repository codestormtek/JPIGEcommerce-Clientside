modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin Panel"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd Frontend.WEB && npm run dev'"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd Api && PORT=8000 npm run dev'"
waitForPort = 8000

[[workflows.workflow]]
name = "Admin Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd Admin.Web && npm run dev'"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
PORT = "8000"
NODE_ENV = "development"
CORS_ORIGINS = "http://localhost:3001,http://localhost:5000"
BCRYPT_SALT_ROUNDS = "12"
RATE_LIMIT_WINDOW_MS = "900000"
RATE_LIMIT_MAX = "100"
JWT_ACCESS_EXPIRES_IN = "15m"
JWT_REFRESH_EXPIRES_IN = "7d"
LOW_STOCK_THRESHOLD = "5"
AUTO_DISABLE_OUT_OF_STOCK = "false"
LOG_RETENTION_DAYS = "90"
UPLOADS_DIR = "uploads"
MAX_UPLOAD_SIZE_MB = "25"
STORAGE_PROVIDER = "r2"
R2_ACCOUNT_ID = "e90b1199eee199a788c51499000b368c"
