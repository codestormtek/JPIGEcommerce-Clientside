# ─── Database ─────────────────────────────────────────────────────────────────
EXTERNAL_DATABASE_URL="postgresql://USER:PASSWORD@host:5432/dbname?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (comma-separated list of allowed origins) ───────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:5000

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TAX_ENABLED=false

# ─── Scheduled Jobs ───────────────────────────────────────────────────────────
AUTO_CANCEL_ORDER_DELAY_MS=1800000
LOW_STOCK_THRESHOLD=5
AUTO_DISABLE_OUT_OF_STOCK=false
LOG_RETENTION_DAYS=90

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=25

# ─── Exports ──────────────────────────────────────────────────────────────────
EXPORT_MAX_ROWS=50000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=invoices@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_...

# ─── Storage Provider ─────────────────────────────────────────────────────────
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=your-bucket-name
R2_PUBLIC_BASE_URL=https://cdn.yourdomain.com
