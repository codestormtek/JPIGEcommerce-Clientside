# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://jpig_user:PdOviARts3XnVGpfW4mwQmrNy4oeBOrd@dpg-d6jghn14tr6s739g6adg-a.virginia-postgres.render.com/jpig?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=jpig-jwt-secret-change-in-production-2024
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=jpig-jwt-refresh-secret-change-in-production-2024
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (comma-separated list of allowed origins) ───────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Replace with your real Stripe test key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_TAX_ENABLED=false

# ─── Scheduled Jobs (node-cron) ───────────────────────────────────────────────
AUTO_CANCEL_ORDER_DELAY_MS=1800000
LOW_STOCK_THRESHOLD=5
AUTO_DISABLE_OUT_OF_STOCK=false
LOG_RETENTION_DAYS=90

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=25

# ─── Exports ──────────────────────────────────────────────────────────────────
EXPORT_MAX_ROWS=50000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
