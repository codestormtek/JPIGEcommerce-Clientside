# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jpig_db?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (comma-separated list of allowed origins) ───────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Set to true to enable Stripe Tax on checkout (requires Stripe Tax activated on your account)
STRIPE_TAX_ENABLED=false

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Scheduled Jobs ───────────────────────────────────────────────────────────
# How long (ms) before an unpaid order is auto-cancelled (default: 30 minutes)
AUTO_CANCEL_ORDER_DELAY_MS=1800000
# Qty threshold below which an item is considered "low stock"
LOW_STOCK_THRESHOLD=5
# Set to true to automatically unpublish product items with 0 stock
AUTO_DISABLE_OUT_OF_STOCK=false
# How many days to retain audit logs, outbox messages, and read notifications
LOG_RETENTION_DAYS=90

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Directory (relative to Api/) where uploaded files are stored
UPLOADS_DIR=uploads
# Maximum allowed file size in megabytes
MAX_UPLOAD_SIZE_MB=25

# ─── Storage Provider ─────────────────────────────────────────────────────────
# 'r2' uses Cloudflare R2 (default). Set to 'local' to store files on disk.
# ─── Storage Provider ─────────────────────────────────────────────────────────
# 'r2' uses Cloudflare R2 (default). Set to 'local' to store files on disk.
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=e90b1199eee199a788c51499000b368c
R2_ACCESS_KEY_ID=714b82227453cd674d0502dea1c24169
R2_SECRET_ACCESS_KEY=a3591c6828d362c12fa7ee8a0d8dd84209ed12abfffbf2dad62400cc0f6f7ba8
R2_BUCKET=jpig-media
R2_PUBLIC_BASE_URL=https://cdn.thejigglingpig.com

# ─── Exports ──────────────────────────────────────────────────────────────────
# Maximum number of rows allowed in a single export job
EXPORT_MAX_ROWS=50000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
# The "from" address must be a verified domain in your Resend account
RESEND_FROM=invoices@yourdomain.com
# Signing secret from Resend Webhooks dashboard (starts with whsec_)
RESEND_WEBHOOK_SECRET=whsec_...

# ─── Dashboard Cache TTLs ─────────────────────────────────────────────────────
# How long (seconds) to cache live/transactional metric queries
CACHE_LIVE_TTL_SECONDS=60
# How long (seconds) to cache pre-aggregated MetricDaily reads
CACHE_AGGREGATE_TTL_SECONDS=600

